        "# 2. Slice the sample and length\n",
        "sample_points = points[SAMPLE : SAMPLE + 1].to(device)\n",
        "sample_length = lengths[SAMPLE : SAMPLE + 1].to(device)\n",
        "\n",
        "# 3. Decode prediction and strip padding\n",
        "predicted_order = model.decode(sample_points, sample_length)\n",
        "predicted_order = predicted_order[0].cpu().numpy()[:valid_len]\n",
        "\n",
        "# 4. Get Ground Truth (GT) indices and strip padding\n",
        "gt_indices = gt_order[SAMPLE].cpu().numpy()[:valid_len]\n",
        "\n",
        "# 5. Extract raw coordinates sorted by GT order\n",
        "true_points = sample_points[0].cpu().numpy()[gt_indices]\n",
        "\n",
        "# 6. Map original point indices to their predicted sequence position\n",
        "pred_index_map = {pt_idx: pred_step for pred_step, pt_idx in enumerate(predicted_order)}\n",
        "\n",
        "# 7. Align predicted indices with the GT sequence\n",
        "pred_indices_aligned = []\n",
        "for point_idx in gt_indices:\n",
        "    pred_step = pred_index_map.get(point_idx, -1)\n",
